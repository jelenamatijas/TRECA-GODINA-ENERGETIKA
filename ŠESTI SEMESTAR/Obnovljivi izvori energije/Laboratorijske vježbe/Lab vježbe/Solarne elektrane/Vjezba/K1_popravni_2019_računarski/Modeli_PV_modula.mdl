      RequestExecContextInheritance off
      Object {
	$PropName		"MaskObject"
	$ObjectID		67
	$ClassName		"Simulink.Mask"
	Initialization		"%============================================================\n% Originator:\n%   University of Banj"
	"a Luka\n%   Faculty of Electrical Engineering \n%   Department of Electrical Power Engineering\n%   \n% History:\n%  "
	" 16.1.2016. Version 1 \n%============================================================\n% Calculation of PV module par"
	"ameters\n%------------------------------------------------------------\nk       = 1.381e-23; % [J/K] Boltzmann consta"
	"nt\nq       = 1.602e-19; % [C] Charge of an electron\nTc_ref  = 25;        % [C] PV cell temperature at STC\nG_ref   "
	"= 1000;      % [W/m2] Irradiance at STC\nmi_sc   = 0.0013;    % [A/C] Temperature coefficient of the \n              "
	"       %       short circuit current     \n\n% eps_g - [eV] Band gap of the material\nswitch PV_mat\n    case 1\n    "
	"    eps_g = 1.12;\n    case 2\n        eps_g = 1.42;\n    case 3\n        eps_g = 1.50;\n    case 4\n        eps_g = "
	"1.35;\nend\n\n% A - Ideality factor\nswitch PV_teh\n    case 1\n        A = 1.2;\n    case 2\n        A = 1.3;\n    c"
	"ase 3\n        A = 1.8;\n    case 4\n        A = 3.3;\n    case 5\n        A = 5;\n    case 6\n        A = 1.5;\n    "
	"case 7\n        A = 1.5;\n    case 8\n        A = 1.3;\nend\n%======================================================="
	"====\n"
	Display			"plot([0.35 0.45],[0.3 0.7]);\nplot([0.45 0.55],[0.3 0.7]);\nplot([0.55 0.65],[0.3 0.7]);\nplot([0.65 0.75]"
	",[0.3 0.7]);\nplot([0.35 0.65],[0.3 0.3]);\nplot([0.375 0.675],[0.4 0.4]);\nplot([0.4 0.7],[0.5 0.5]);\nplot([0.425 0"
	".725],[0.6 0.6]);\nplot([0.45 0.75],[0.7 0.7]);\ntext(0.5,0.9,'PV module','horizontalAlignment', 'center');\ntext(0.8"
	"5,0.1,'ETF BL','horizontalAlignment', 'center');"
	IconOpaque		"transparent"
	IconUnits		"normalized"
	Array {
	  Type			  "Simulink.MaskParameter"
	  Dimension		  10
	  Object {
	    $ObjectID		    68
	    Type		    "edit"
	    Name		    "Isc_ref"
	    Prompt		    "Short-circuit current [A]"
	    Value		    "5.61"
	  }
	  Object {
	    $ObjectID		    69
	    Type		    "edit"
	    Name		    "Uoc_ref"
	    Prompt		    "Open-circuit voltage [V]"
	    Value		    "45.4"
	  }
	  Object {
	    $ObjectID		    70
	    Type		    "edit"
	    Name		    "Imp"
	    Prompt		    "Current at Pmax [A]"
	    Value		    "5.27"
	  }
	  Object {
	    $ObjectID		    71
	    Type		    "edit"
	    Name		    "Ump"
	    Prompt		    "Voltage at Pmax [V]"
	    Value		    "38"
	  }
	  Object {
	    $ObjectID		    72
	    Type		    "edit"
	    Name		    "Rs"
	    Prompt		    "Series resistance of the PV module [Ohms]"
	    Value		    "0.1948"
	  }
	  Object {
	    $ObjectID		    73
	    Type		    "edit"
	    Name		    "Rp"
	    Prompt		    "Shunt resistance of the PV module [Ohms]"
	    Value		    "1516.5"
	  }
	  Object {
	    $ObjectID		    74
	    Type		    "edit"
	    Name		    "Ns"
	    Prompt		    "Number of cells connected in series"
	    Value		    "72"
	  }
	  Object {
	    $ObjectID		    75
	    Type		    "popup"
	    Array {
	      Type		      "Cell"
	      Dimension		      4
	      Cell		      "Si"
	      Cell		      "GaAs"
