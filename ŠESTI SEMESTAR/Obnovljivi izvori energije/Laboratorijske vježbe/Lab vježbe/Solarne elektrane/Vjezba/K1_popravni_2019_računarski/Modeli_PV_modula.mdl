	  Object {
	    $ObjectID		    76
	    Type		    "popup"
	    Array {
	      Type		      "Cell"
	      Dimension		      8
	      Cell		      "Si-mono"
	      Cell		      "Si-poly"
	      Cell		      "a-Si-H"
	      Cell		      "a-Si-H tandem"
	      Cell		      "a-Si-H triple"
