    Block {
      BlockType		      SubSystem
      Name		      "PV module2"
      SID		      "281"
      Ports		      [3, 1]
      Position		      [145, 282, 280, 358]
      ZOrder		      2
      BackgroundColor	      "cyan"
      RequestExecContextInheritance off
      Object {
	$PropName		"MaskObject"
	$ObjectID		45
	$ClassName		"Simulink.Mask"
	Initialization		"%============================================================\n% Originator:\n%   University of Banj"
	"a Luka\n%   Faculty of Electrical Engineering \n%   Department of Electrical Power Engineering\n%   \n% History:\n%  "
	" 16.1.2016. Version 1 \n%============================================================\n% Calculation of PV module par"
	"ameters\n%------------------------------------------------------------\nk       = 1.381e-23; % [J/K] Boltzmann consta"
	"nt\nq       = 1.602e-19; % [C] Charge of an electron\nTc_ref  = 25;        % [C] PV cell temperature at STC\nG_ref   "
	"= 1000;      % [W/m2] Irradiance at STC\nmi_sc   = 0.0013;    % [A/C] Temperature coefficient of the \n              "
	"       %       short circuit current     \n\n% eps_g - [eV] Band gap of the material\nswitch PV_mat\n    case 1\n    "
	"    eps_g = 1.12;\n    case 2\n        eps_g = 1.42;\n    case 3\n        eps_g = 1.50;\n    case 4\n        eps_g = "
	"1.35;\nend\n\n% A - Ideality factor\nswitch PV_teh\n    case 1\n        A = 1.2;\n    case 2\n        A = 1.3;\n    c"
	"ase 3\n        A = 1.8;\n    case 4\n        A = 3.3;\n    case 5\n        A = 5;\n    case 6\n        A = 1.5;\n    "
	"case 7\n        A = 1.5;\n    case 8\n        A = 1.3;\nend\n%======================================================="
	"====\n"
