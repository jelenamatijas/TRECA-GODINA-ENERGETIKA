      MaskIconOpaque	      off
      MaskIconRotate	      "none"
      MaskPortRotate	      "default"
      MaskIconUnits	      "normalized"
      MaskValueString	      "3.11|21.8|2.88|17|0.45|310|36|Si|Si-poly|on"
