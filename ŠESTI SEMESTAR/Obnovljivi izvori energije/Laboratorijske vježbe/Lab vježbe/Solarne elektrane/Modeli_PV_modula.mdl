      PropExecContextOutsideSubsystem off
      RTWSystemCode	      "Auto"
      FunctionWithSeparateData off
      Opaque		      off
      RequestExecContextInheritance off
      MaskHideContents	      off
      MaskPromptString	      "Short-circuit current [A]|Open-circuit voltage [V]|Current at Pmax [A]|Voltage at Pmax ["
      "V]|Series resistance of the PV module [Ohms]|Shunt resistance of the PV module [Ohms]|Number of cells connected "
      "in series|Material|PV cell technology"
      MaskStyleString	      "edit,edit,edit,edit,edit,edit,edit,popup(Si|GaAs|CdTe|InP),popup(Si-mono|Si-poly|a-Si-H|a"
      "-Si-H tandem|a-Si-H triple|CdTe|CTs|AsGa)"
      MaskVariables	      "Isc_ref=@1;Uoc_ref=@2;Imp=@3;Ump=@4;Rs=@5;Rp=@6;Ns=@7;PV_mat=@8;PV_teh=@9;"
      MaskTunableValueString  "on,on,on,on,on,on,on,on,on"
      MaskCallbackString      "||||||||"
      MaskEnableString	      "on,on,on,on,on,on,on,on,on"
      MaskVisibilityString    "on,on,on,on,on,on,on,on,on"
      MaskToolTipString	      "on,on,on,on,on,on,on,on,on"
      MaskInitialization      "%============================================================\n% Originator:\n%   Unive"
      "rsity of Banja Luka\n%   Faculty of Electrical Engineering \n%   Department of Electrical Power Engineering\n%  "
      " \n% History:\n%   16.1.2016. Version 1 \n%============================================================\n% Calcu"
      "lation of PV module parameters\n%------------------------------------------------------------\nk       = 1.381e-"
      "23; % [J/K] Boltzmann constant\nq       = 1.602e-19; % [C] Charge of an electron\nTc_ref  = 25;        % [C] PV "
      "cell temperature at STC\nG_ref   = 1000;      % [W/m2] Irradiance at STC\nmi_sc   = 0.0013;    % [A/C] Temperatu"
      "re coefficient of the \n                     %       short circuit current     \n\n% eps_g - [eV] Band gap of th"
      "e material\nswitch PV_mat\n    case 1\n        eps_g = 1.12;\n    case 2\n        eps_g = 1.42;\n    case 3\n   "
      "     eps_g = 1.50;\n    case 4\n        eps_g = 1.35;\nend\n\n% A - Ideality factor\nswitch PV_teh\n    case 1\n"
      "        A = 1.2;\n    case 2\n        A = 1.3;\n    case 3\n        A = 1.8;\n    case 4\n        A = 3.3;\n    "
      "case 5\n        A = 5;\n    case 6\n        A = 1.5;\n    case 7\n        A = 1.5;\n    case 8\n        A = 1.3;"
      "\nend\n%===========================================================\n"
      MaskDisplay	      "plot([0.35 0.45],[0.3 0.7]);\nplot([0.45 0.55],[0.3 0.7]);\nplot([0.55 0.65],[0.3 0.7]);\nplo"
      "t([0.65 0.75],[0.3 0.7]);\nplot([0.35 0.65],[0.3 0.3]);\nplot([0.375 0.675],[0.4 0.4]);\nplot([0.4 0.7],[0.5 0.5"
      "]);\nplot([0.425 0.725],[0.6 0.6]);\nplot([0.45 0.75],[0.7 0.7]);\ntext(0.5,0.9,'PV module','horizontalAlignment"
      "', 'center');\ntext(0.85,0.1,'ETF BL','horizontalAlignment', 'center');"
      MaskIconFrame	      on
      MaskIconOpaque	      off
      MaskIconRotate	      "none"
      MaskPortRotate	      "default"
      MaskIconUnits	      "normalized"
      MaskValueString	      "3.11|21.8|2.88|17|0.45|310|36|Si|Si-poly"
